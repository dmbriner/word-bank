{
  "manifest_version": 3,
  "name": "Dana's Word Bank Capture",
  "version": "0.1.0",
  "description": "Private capture tool for saving selected words to Dana's Word Bank.",
  "permissions": ["activeTab", "contextMenus", "storage"],
  "host_permissions": ["https://api.dictionaryapi.dev/*", "https://api.github.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dana's Word Bank"
  },
  "options_page": "options.html"
}
